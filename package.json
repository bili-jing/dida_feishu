{
  "name": "dida_feishu",
  "version": "1.0.0",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --hot index.ts",
    "sync": "bun sync.ts",
    "build": "bun run build:win && bun run build:mac",
    "build:win": "bun build --compile --target=bun-windows-x64 index.ts --outfile dist/dida-feishu.exe",
    "build:mac": "bun build --compile --target=bun-darwin-arm64 index.ts --outfile dist/dida-feishu-macos",
    "build:linux": "bun build --compile --target=bun-linux-x64 index.ts --outfile dist/dida-feishu-linux"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/qrcode": "^1.5.6"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "qrcode": "^1.5.4"
  }
}
